                    start: 83,
                    end: 100,
                },
            },
            Label {
                style: Secondary,
                message: "type defined here",
                span: Span {
                    start: 123,
                    end: 132,
                },
            },
        ],
        note: Some(
            "help: timestamp has to be in RFC3339 format",
        ),
    },
]
